{
	"info": {
		"_postman_id": "tradecontroller-{{$randomUUID}}",
		"name": "TradeController Collection",
		"description": "API collection for TradeController - Core trade operations including CRUD, filtering, and batch operations",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Trade Details Operations",
			"item": [
				{
					"name": "Get Trade Details by Portfolio and Symbols",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});",
									"",
									"if (pm.response.json().length > 0) {",
									"    pm.test(\"Trade has required fields\", function () {",
									"        const trade = pm.response.json()[0];",
									"        pm.expect(trade).to.have.property('tradeId');",
									"        pm.expect(trade).to.have.property('symbol');",
									"        pm.expect(trade).to.have.property('portfolioId');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/trades/details/portfolio/{{portfolioId}}?symbols=AAPL,TSLA",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"trades",
								"details",
								"portfolio",
								"{{portfolioId}}"
							],
							"query": [
								{
									"key": "symbols",
									"value": "AAPL,TSLA",
									"description": "Optional symbols filter"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Add New Trade",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Trade created successfully\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('tradeId');",
									"    pm.expect(response.symbol).to.eql('MSFT');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"symbol\": \"MSFT\",\n  \"side\": \"BUY\",\n  \"type\": \"MARKET\",\n  \"status\": \"EXECUTED\",\n  \"quantity\": 50,\n  \"price\": 300.00,\n  \"totalValue\": 15000.00,\n  \"portfolioId\": \"{{portfolioId}}\",\n  \"traderId\": \"{{traderId}}\",\n  \"tradeDate\": \"2025-01-11T15:00:00\",\n  \"userId\": \"{{traderId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/trades/details",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"trades",
								"details"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Existing Trade",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Trade updated successfully\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('tradeId');",
									"    pm.expect(response.quantity).to.eql(75);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"tradeId\": \"{{tradeId}}\",\n  \"symbol\": \"MSFT\",\n  \"side\": \"BUY\",\n  \"type\": \"MARKET\",\n  \"status\": \"EXECUTED\",\n  \"quantity\": 75,\n  \"price\": 305.00,\n  \"totalValue\": 22875.00,\n  \"portfolioId\": \"{{portfolioId}}\",\n  \"traderId\": \"{{traderId}}\",\n  \"userId\": \"{{traderId}}\",\n  \"tradeDate\": \"2025-01-11T15:00:00\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/trades/details/{{tradeId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"trades",
								"details",
								"{{tradeId}}"
							]
						}
					},
					"response": []
				},
