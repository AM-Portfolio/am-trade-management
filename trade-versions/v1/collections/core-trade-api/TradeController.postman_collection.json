		{
			"name": "Trade Filtering",
			"item": [
				{
					"name": "Filter Trades by Multiple Criteria",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has pagination structure\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('content');",
									"    pm.expect(response).to.have.property('pageable');",
									"    pm.expect(response).to.have.property('totalElements');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/trades/filter?portfolioIds={{portfolioId}}&symbols=AAPL,TSLA&statuses=EXECUTED&startDate=2020-01-01&endDate=2025-12-31&page=0&size=20",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"trades",
								"filter"
							],
							"query": [
								{
									"key": "portfolioIds",
									"value": "{{portfolioId}}"
								},
								{
									"key": "symbols",
									"value": "AAPL,TSLA"
								},
								{
									"key": "statuses",
									"value": "EXECUTED"
								},
								{
									"key": "startDate",
									"value": "2020-01-01"
								},
								{
									"key": "endDate",
									"value": "2025-12-31"
								},
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "20"
								}
							]
						}
					},
					"response": []
				}
			]
		},
