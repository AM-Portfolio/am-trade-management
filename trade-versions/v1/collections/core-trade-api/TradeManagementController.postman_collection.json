				{
					"name": "Get Trades by Day",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an object\", function () {",
									"    pm.expect(pm.response.json()).to.be.an('object');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/trades/calendar/day?date=2020-12-15&portfolioId={{portfolioId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"trades",
								"calendar",
								"day"
							],
							"query": [
								{
									"key": "date",
									"value": "2020-12-15",
									"description": "Date in YYYY-MM-DD format"
								},
								{
									"key": "portfolioId",
									"value": "{{portfolioId}}",
									"description": "Optional portfolio filter"
								}
							]
						}
					},
					"response": []
				},
