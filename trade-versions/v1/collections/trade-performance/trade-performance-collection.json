{
    "info": {
        "name": "Trade Performance API",
        "description": "API for detailed trade performance analysis. See `tradePerformanceSchema` variable for full JSON Schema.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get Performance Summary",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/performance/summary?portfolioId={{portfolio_id}}&startDate=2024-01-01&endDate=2024-12-31",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "performance",
                        "summary"
                    ],
                    "query": [
                        {
                            "key": "portfolioId",
                            "value": "{{portfolio_id}}"
                        },
                        {
                            "key": "startDate",
                            "value": "2024-01-01"
                        },
                        {
                            "key": "endDate",
                            "value": "2024-12-31"
                        }
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Get Daily Performance",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/performance/daily?portfolioId={{portfolio_id}}&limit=10",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "performance",
                        "daily"
                    ],
                    "query": [
                        {
                            "key": "portfolioId",
                            "value": "{{portfolio_id}}"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        }
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Get Timing Analysis",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/performance/timing?portfolioId={{portfolio_id}}",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "performance",
                        "timing"
                    ],
                    "query": [
                        {
                            "key": "portfolioId",
                            "value": "{{portfolio_id}}"
                        }
                    ]
                }
            },
            "response": []
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080"
        },
        {
            "key": "portfolio_id",
            "value": "p1"
        },
        {
            "key": "jwt_token",
            "value": "YOUR_JWT_TOKEN_HERE"
        },
