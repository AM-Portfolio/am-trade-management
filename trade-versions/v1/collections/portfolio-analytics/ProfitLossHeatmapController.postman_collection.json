{
	"info": {
		"_postman_id": "profitlossheatmapcontroller-{{$randomUUID}}",
		"name": "ProfitLossHeatmapController Collection",
		"description": "API collection for ProfitLossHeatmapController - Profit & Loss visualization data with yearly, monthly, and daily granularity",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Heatmap Data",
			"item": [
				{
					"name": "Get Yearly P&L Heatmap",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Heatmap data has required structure\", function () {",
									"    const heatmap = pm.response.json();",
									"    pm.expect(heatmap).to.have.property('granularityType');",
									"    pm.expect(heatmap).to.have.property('periodData');",
									"    pm.expect(heatmap.granularityType).to.eql('YEARLY');",
									"});",
									"",
									"if (pm.response.json().periodData && pm.response.json().periodData.length > 0) {",
									"    pm.test(\"Period data has P&L metrics\", function () {",
									"        const period = pm.response.json().periodData[0];",
									"        pm.expect(period).to.have.property('periodId');",
									"        pm.expect(period).to.have.property('profitLoss');",
									"        pm.expect(period).to.have.property('winCount');",
									"        pm.expect(period).to.have.property('lossCount');",
									"        pm.expect(period).to.have.property('winRate');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/heatmap/yearly?portfolioId={{portfolioId}}&year=2020&includeTradeDetails=false",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"heatmap",
								"yearly"
							],
							"query": [
								{
									"key": "portfolioId",
									"value": "{{portfolioId}}"
								},
								{
									"key": "year",
									"value": "2020",
									"description": "Year for heatmap data"
								},
								{
									"key": "includeTradeDetails",
									"value": "false",
									"description": "Whether to include trade details"
								}
							]
						}
					},
					"response": []
				},
