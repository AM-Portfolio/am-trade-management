{
	"info": {
		"_postman_id": "userpreferencescontroller-{{$randomUUID}}",
		"name": "UserPreferencesController Collection",
		"description": "API collection for UserPreferencesController - User settings and configurations",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Dashboard Preferences",
			"item": [
				{
					"name": "Get Dashboard Preferences",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Response contains dashboard preferences\", function () {",
									"        const response = pm.response.json();",
									"        pm.expect(response).to.have.property('userId');",
									"        pm.expect(response).to.have.property('preferences');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/preferences/dashboard?userId={{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"preferences",
								"dashboard"
							],
							"query": [
								{
									"key": "userId",
									"value": "{{userId}}",
									"description": "User ID to get preferences for"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Save Dashboard Preferences",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains saved preferences\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('userId');",
									"    pm.expect(response).to.have.property('preferences');",
									"    pm.expect(response.preferences).to.have.property('theme', 'dark');",
									"});",
									"",
									"pm.test(\"Preferences include layout configuration\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.preferences).to.have.property('layout');",
									"    pm.expect(response.preferences.layout).to.have.property('sidebarCollapsed', false);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"preferences\": {\n    \"theme\": \"dark\",\n    \"language\": \"en-US\",\n    \"timezone\": \"America/New_York\",\n    \"dateFormat\": \"MM/dd/yyyy\",\n    \"currency\": \"USD\",\n    \"layout\": {\n      \"sidebarCollapsed\": false,\n      \"dashboardLayout\": \"grid\",\n      \"defaultPage\": \"/dashboard\"\n    },\n    \"notifications\": {\n      \"email\": true,\n      \"push\": false,\n      \"tradeAlerts\": true,\n      \"portfolioUpdates\": true\n    },\n    \"charts\": {\n      \"defaultTimeframe\": \"1D\",\n      \"candlestickStyle\": \"standard\",\n      \"indicators\": [\"RSI\", \"MACD\"]\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/preferences/dashboard?userId={{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"preferences",
								"dashboard"
							],
							"query": [
								{
									"key": "userId",
									"value": "{{userId}}",
									"description": "User ID to save preferences for"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Reset Dashboard Preferences",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains reset preferences\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('userId');",
									"    pm.expect(response).to.have.property('preferences');",
									"});",
									"",
									"pm.test(\"Preferences are reset to defaults\", function () {",
									"    const response = pm.response.json();",
									"    console.log('Preferences reset to default values');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/preferences/dashboard/reset?userId={{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"preferences",
								"dashboard",
								"reset"
							],
							"query": [
								{
									"key": "userId",
									"value": "{{userId}}",
									"description": "User ID to reset preferences for"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8073"
		},
		{
			"key": "userId",
			"value": "sample-user-id"
		}
	]
}