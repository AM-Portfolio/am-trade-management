									"pm.test(\"Comparison includes both portfolios\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('comparedEntities');",
									"    pm.expect(response.comparedEntities).to.be.an('array');",
									"    pm.expect(response.comparedEntities.length).to.equal(2);",
