				{
					"name": "Find Replays by Symbol",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});",
									"",
									"pm.test(\"All replays have correct symbol\", function () {",
									"    const replays = pm.response.json();",
									"    replays.forEach(replay => {",
									"        pm.expect(replay.symbol).to.equal('AAPL');",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/analytics/trade-replays/symbol/AAPL",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
