{
	"info": {
		"_postman_id": "tradereplaycontroller-{{$randomUUID}}",
		"name": "TradeReplayController Collection",
		"description": "API collection for TradeReplayController - Trade replay scenarios and analytics",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Replay Management",
			"item": [
				{
					"name": "Create Trade Replay",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response contains replay data\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('replayId');",
									"    pm.expect(response).to.have.property('symbol');",
									"});",
									"",
									"// Save replay ID for other requests",
									"if (pm.response.code === 201) {",
									"    const replayId = pm.response.json().replayId;",
									"    pm.environment.set('replayId', replayId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"symbol\": \"AAPL\",\n  \"portfolioId\": \"{{portfolioId}}\",\n  \"strategyId\": \"sample-strategy-id\",\n  \"originalTradeId\": \"sample-trade-id\",\n  \"startDate\": \"2020-01-01T09:30:00\",\n  \"endDate\": \"2020-01-01T16:00:00\",\n  \"initialCapital\": 10000.0,\n  \"replayType\": \"BACKTEST\",\n  \"parameters\": {\n    \"stopLoss\": 0.02,\n    \"takeProfit\": 0.05\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/analytics/trade-replays",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"analytics",
								"trade-replays"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Trade Replay by ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Response contains replay details\", function () {",
									"        const response = pm.response.json();",
									"        pm.expect(response).to.have.property('id');",
									"        pm.expect(response).to.have.property('symbol');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/analytics/trade-replays/{{replayId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"analytics",
								"trade-replays",
								"{{replayId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete Trade Replay",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 204 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([204, 404]);",
									"});",
									"",
									"if (pm.response.code === 204) {",
									"    pm.test(\"Trade replay deleted successfully\", function () {",
									"        console.log('Trade replay deleted successfully');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/analytics/trade-replays/{{replayId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"analytics",
								"trade-replays",
								"{{replayId}}"
							]
						}
					},
					"response": []
				}
			]
		},
