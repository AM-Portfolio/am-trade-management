                "tradeCount": {
                    "type": "integer"
                },
                "winCount": {
                    "type": "integer"
                },
                "lossCount": {
                    "type": "integer"
                },
                "winRate": {
                    "type": "number"
                },
                "totalProfitLoss": {
                    "type": "number"
                },
                "metrics": {
                    "$ref": "#/definitions/PerformanceMetrics"
                }
