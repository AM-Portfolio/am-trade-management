                "winCount": {
                    "type": "integer"
                },
                "lossCount": {
                    "type": "integer"
                },
                "winRate": {
                    "type": "number"
                },
                "totalProfitLoss": {
                    "type": "number"
                },
                "averageWinAmount": {
                    "type": "number"
                },
                "averageLossAmount": {
                    "type": "number"
                },
                "averageHoldingTime": {
                    "type": "number"
                },
                "metrics": {
                    "$ref": "#/definitions/PerformanceMetrics"
                }
            }
        },
        "DayOfWeekPerformance": {
            "type": "object",
            "properties": {
                "dayOfWeek": {
                    "type": "string"
                },
                "dayOrder": {
                    "type": "integer"
                },
                "tradeCount": {
                    "type": "integer"
                },
                "winCount": {
                    "type": "integer"
                },
                "lossCount": {
                    "type": "integer"
                },
                "winRate": {
                    "type": "number"
                },
                "totalProfitLoss": {
                    "type": "number"
                },
                "averageWinAmount": {
                    "type": "number"
                },
                "averageLossAmount": {
                    "type": "number"
                },
                "averageHoldingTime": {
                    "type": "number"
                },
                "metrics": {
