        "TradePerformanceSummary": {
            "type": "object",
            "properties": {
                "totalTrades": {
                    "type": "integer"
                },
                "winningTrades": {
                    "type": "integer"
                },
                "losingTrades": {
                    "type": "integer"
                },
                "breakEvenTrades": {
                    "type": "integer"
                },
                "winPercentage": {
                    "type": "number"
                },
                "totalProfitLoss": {
                    "type": "number"
                },
                "averageProfitPerTrade": {
                    "type": "number"
                },
                "averageWinAmount": {
                    "type": "number"
                },
                "averageLossAmount": {
                    "type": "number"
                },
                "averageHoldingTimeWin": {
                    "type": "number"
                },
                "averageHoldingTimeLoss": {
                    "type": "number"
                },
                "maxDrawdown": {
                    "type": "number"
                },
                "profitFactor": {
                    "type": "number"
                },
                "largestWin": {
                    "type": "number"
                },
                "largestLoss": {
                    "type": "number"
                },
                "metrics": {
                    "$ref": "#/definitions/PerformanceMetrics"
                }
            }
        },
        "DailyPerformance": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string",
                    "format": "date"
                },
                "totalProfitLoss": {
                    "type": "number"
                },
                "tradeCount": {
                    "type": "integer"
                },
                "winCount": {
                    "type": "integer"
                },
                "lossCount": {
                    "type": "integer"
                },
                "winRate": {
                    "type": "number"
                },
                "bestTradeSymbol": {
                    "type": "string"
                },
                "bestTradePnL": {
                    "type": "number"
                },
                "metrics": {
                    "$ref": "#/definitions/PerformanceMetrics"
                }
            }
        },
        "TimingAnalysis": {
            "type": "object",
            "properties": {
                "hourlyPerformance": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/HourlyPerformance"
                    }
                },
                "dayOfWeekPerformance": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/DayOfWeekPerformance"
                    }
                },
                "monthlyPerformance": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/MonthlyPerformance"
                    }
                },
                "yearlyPerformance": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/YearlyPerformance"
                    }
                },
                "weeklyPerformance": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/WeeklyPerformance"
                    }
                },
                "bestTradingHour": {
                    "type": "integer"
                },
                "worstTradingHour": {
                    "type": "integer"
                },
                "bestTradingDay": {
                    "type": "string"
                },
                "worstTradingDay": {
                    "type": "string"
                },
                "bestTradingMonth": {
                    "type": "string"
                },
                "worstTradingMonth": {
                    "type": "string"
                }
            }
