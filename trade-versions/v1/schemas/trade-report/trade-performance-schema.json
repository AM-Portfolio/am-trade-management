        "PerformanceMetrics": {
            "type": "object",
            "properties": {
                "avgHoldTime": {
                    "type": "number"
                },
                "longestTradeDuration": {
                    "type": "number"
                },
                "maxTradingWeeksDuration": {
                    "type": "number"
                },
                "avgTradingWeeksDuration": {
                    "type": "number"
                },
                "avgGrossTradePnL": {
                    "type": "number"
                },
                "avgLoss": {
                    "type": "number"
                },
                "avgMaxTradeLoss": {
                    "type": "number"
                },
                "avgMaxTradeProfit": {
                    "type": "number"
                },
                "avgTradeWinLossRatio": {
                    "type": "number"
                },
                "avgWeeklyGrossPnL": {
                    "type": "number"
                },
                "avgWeeklyWinLossRatio": {
                    "type": "number"
                },
                "avgWin": {
                    "type": "number"
                },
                "grossPnL": {
                    "type": "number"
                },
                "largestLosingTrade": {
                    "type": "number"
                },
                "largestProfitableTrade": {
                    "type": "number"
                },
                "profitFactor": {
                    "type": "number"
                },
                "avgWeeklyGrossDrawdown": {
                    "type": "number"
                },
                "avgPlannedRMultiple": {
                    "type": "number"
                },
                "avgRealizedRMultiple": {
                    "type": "number"
                },
                "breakevenDays": {
                    "type": "integer"
                },
                "breakevenTrades": {
                    "type": "integer"
                },
                "losingDays": {
                    "type": "integer"
                },
                "maxWeeklyGrossDrawdown": {
                    "type": "number"
                },
                "avgWeeklyWinPercentage": {
                    "type": "number"
                },
                "longsWinPercentage": {
                    "type": "number"
                },
                "maxConsecutiveLosingWeeks": {
                    "type": "integer"
                },
                "maxConsecutiveLosses": {
                    "type": "integer"
                },
                "maxConsecutiveWinningWeeks": {
                    "type": "integer"
                },
                "maxConsecutiveWins": {
                    "type": "integer"
                },
                "shortsWinPercentage": {
                    "type": "number"
