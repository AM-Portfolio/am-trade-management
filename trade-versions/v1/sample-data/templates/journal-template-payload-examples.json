        "createIntradayCheckinTemplate": {
            "name": "Intra-day Check-in",
            "description": "This template is used to check-in with yourself throughout the trading day. Checking yourself throughout the day helps you in several ways such as: Keeping you from having a strong bias because you're sharing what is truly happening in the market, Holds you accountable to what you've previously said in your check-ins, Makes your EOD journaling easier since all your intra-day thoughts and executions are in your check-ins",
            "category": "DAILY_CHECKIN",
            "fields": [
                {
                    "fieldId": "market_observation",
                    "fieldLabel": "What you're currently seeing in the market",
                    "fieldType": "TEXTAREA",
                    "placeholder": "Write down what you're currently seeing in the market, if you're thinking of entering anything, did enter anything & why",
                    "required": false,
                    "order": 1,
                    "helpText": "Describe current market conditions and your observations"
                },
                {
                    "fieldId": "chart_screenshot",
                    "fieldLabel": "Chart Screenshot",
                    "fieldType": "IMAGE_UPLOAD",
                    "placeholder": "Include a picture of the chart from the moment in time",
                    "required": false,
                    "order": 2,
                    "helpText": "Upload a screenshot of your chart at this moment"
                },
                {
                    "fieldId": "bias_check",
                    "fieldLabel": "Bias Prevention",
                    "fieldType": "CHECKBOX",
                    "defaultValue": "true",
                    "required": false,
                    "order": 3,
                    "helpText": "Keeping you from having a strong bias because you're sharing what is truly happening in the market"
                },
                {
                    "fieldId": "accountability",
                    "fieldLabel": "Accountability Check",
                    "fieldType": "CHECKBOX",
                    "defaultValue": "true",
                    "required": false,
                    "order": 4,
                    "helpText": "Holds you accountable to what you've previously said in your check-ins"
                },
                {
                    "fieldId": "eod_helper",
                    "fieldLabel": "EOD Journaling Helper",
                    "fieldType": "CHECKBOX",
                    "defaultValue": "true",
                    "required": false,
                    "order": 5,
                    "helpText": "Makes your EOD journaling easier since all your intra-day thoughts and executions are in your check-ins"
                }
            ],
            "isSystemTemplate": true,
            "isRecommended": true,
            "createdBy": "system",
            "tags": [
                "daily",
                "check-in",
                "tradezella"
            ],
            "thumbnailUrl": "https://example.com/thumbnails/intraday-checkin.png"
        },
