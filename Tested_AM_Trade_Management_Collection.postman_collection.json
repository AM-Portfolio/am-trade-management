            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user_fresh_tester\",\n  \"portfolioId\": \"portfolio_main_001\",\n  \"symbol\": \"AAPL\",\n  \"quantity\": 10,\n  \"entryPrice\": 150.00,\n  \"tradeDate\": \"2024-05-15T10:00:00\",\n  \"status\": \"OPEN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/trades/details",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "trades", "details"]
            }
          }
        },
