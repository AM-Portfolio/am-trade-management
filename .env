# GitHub Package Registry
GITHUB_PACKAGES_USERNAME=XXXXXXX
GITHUB_PACKAGES_TOKEN=XXXXXXXXXXXXXXXX

# Infrastructure (Central)
# Using internal container names instead of host.docker.internal for better reliability in am-network
MONGODB_URL=mongodb://admin:password123@am_mongodb:27017/trade_management?authSource=admin
MONGODB_DATABASE=trade_management
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password123

REDIS_HOSTNAME=am_redis
REDIS_PORT=6379
REDIS_PASSWORD=password123

# Kafka: using am_kafka:9092 which is typically the internal listener
KAFKA_BOOTSTRAP_SERVERS=am_kafka:9092
KAFKA_CONSUMER_GROUP_ID=am-trade-group

# Application Configuration
AM_TRADE_API_URL=http://am-trade-service:8080
AM_TRADE_MAX_RETRIES=5

# JWT Secrets
INTERNAL_JWT_SECRET=internal-service-super-secret-key-32chars-minimum-change-in-prod
JWT_SECRET=internal-service-super-secret-key-32chars-minimum-change-in-prod
JWT_ALGORITHM=HS256
