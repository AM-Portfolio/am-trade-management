              "mode": "raw",
              "raw": "{\n  \"portfolioIds\": [\"portfolio-001\", \"portfolio-002\"],\n  \"dateRange\": {\n    \"startDate\": \"2025-01-01\",\n    \"endDate\": \"2025-09-01\"\n  },\n  \"metricTypes\": [\"PERFORMANCE\", \"RISK\", \"DISTRIBUTION\"],\n  \"instruments\": [\"AAPL\", \"MSFT\", \"GOOGL\"],\n  \"instrumentFilters\": {\n    \"sectors\": [\"TECHNOLOGY\", \"HEALTHCARE\"],\n    \"marketCap\": \"LARGE\"\n  },\n  \"tradeCharacteristics\": {\n    \"minDuration\": 1,\n    \"maxDuration\": 30,\n    \"direction\": \"LONG\"\n  },\n  \"profitLossFilters\": {\n    \"minProfitLoss\": 1000,\n    \"maxProfitLoss\": 50000,\n    \"minPositionSize\": 5000,\n    \"maxPositionSize\": 100000\n  },\n  \"groupBy\": [\"STRATEGY\", \"SYMBOL\"],\n  \"includeTradeDetails\": true,\n  \"customFilters\": {\n    \"excludeWeekends\": true,\n    \"onlyRegularHours\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "metrics"]
            },
            "description": "Get trade metrics with flexible filtering options"
