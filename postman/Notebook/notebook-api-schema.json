{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Notebook API Schema",
    "description": "JSON Schema for NotebookController API (Items)",
    "version": "1.0.0",
    "definitions": {
        "NotebookItemType": {
            "type": "string",
            "enum": [
                "FOLDER",
                "NOTE",
                "GOAL"
            ],
            "description": "Type of the notebook item"
        },
        "NotebookItemRequest": {
            "type": "object",
            "required": [
                "userId",
                "type",
                "title"
            ],
            "properties": {
                "userId": {
                    "type": "string",
                    "description": "User ID is required"
                },
                "type": {
                    "$ref": "#/definitions/NotebookItemType"
                },
                "parentId": {
                    "type": "string",
                    "description": "ID of the parent item (Folder or Goal)"
                },
                "title": {
                    "type": "string",
                    "description": "Title of the item"
                },
                "content": {
                    "type": "string",
                    "description": "Content of the note or description of the folder/goal"
                },
                "tagIds": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of tag IDs associated with this item"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Additional metadata"
                },
                "goalDetails": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Specific details if type is GOAL (targetAmount, deadline, etc.)"
                }
            }
        },
        "NotebookItemResponse": {
            "type": "object",
            "required": [
                "id",
                "userId",
                "type",
                "title",
                "createdAt",
                "updatedAt"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique identifier"
                },
                "userId": {
                    "type": "string",
                    "description": "User ID"
                },
                "type": {
                    "$ref": "#/definitions/NotebookItemType"
                },
                "parentId": {
                    "type": "string",
                    "description": "Parent Item ID"
                },
                "title": {
                    "type": "string",
                    "description": "Title"
                },
                "content": {
                    "type": "string",
                    "description": "Content"
                },
                "tagIds": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Associated Tag IDs"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                },
                "goalDetails": {
                    "type": "object",
                    "additionalProperties": true
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "updatedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "ErrorResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string"
                },
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "path": {
                    "type": "string"
                }
            }
        }
    },
    "paths": {
        "/api/v1/notebook/items": {
            "post": {
                "summary": "Create a new notebook item",
                "operationId": "createNotebookItem",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/definitions/NotebookItemRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/NotebookItemResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "get": {
                "summary": "Get notebook items",
                "parameters": [
                    {
                        "name": "userId",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "parentId",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "type",
                        "in": "query",
                        "schema": {
                            "$ref": "#/definitions/NotebookItemType"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/NotebookItemResponse"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/notebook/items/{itemId}": {
            "get": {
                "summary": "Get item by ID",
                "parameters": [
                    {
                        "name": "itemId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/NotebookItemResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            },
            "put": {
                "summary": "Update item",
                "parameters": [
                    {
                        "name": "itemId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/definitions/NotebookItemRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/NotebookItemResponse"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete item",
                "parameters": [
                    {
                        "name": "itemId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Deleted"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        }
    }
}