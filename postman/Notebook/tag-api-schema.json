{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Notebook Tag API Schema",
    "description": "JSON Schema for NotebookController API (Tags)",
    "version": "1.0.0",
    "definitions": {
        "NotebookTagRequest": {
            "type": "object",
            "required": [
                "userId",
                "name",
                "colorHex"
            ],
            "properties": {
                "userId": {
                    "type": "string",
                    "description": "User ID is required"
                },
                "name": {
                    "type": "string",
                    "description": "Tag name"
                },
                "colorHex": {
                    "type": "string",
                    "description": "Hex color code (e.g., #FF0000)"
                }
            }
        },
        "NotebookTagResponse": {
            "type": "object",
            "required": [
                "id",
                "userId",
                "name",
                "colorHex"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique identifier"
                },
                "userId": {
                    "type": "string",
                    "description": "User ID"
                },
                "name": {
                    "type": "string",
                    "description": "Tag name"
                },
                "colorHex": {
                    "type": "string",
                    "description": "Hex color code"
                }
            }
        },
        "ErrorResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string"
                },
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "path": {
                    "type": "string"
                }
            }
        }
    },
    "paths": {
        "/api/v1/notebook/tags": {
            "post": {
                "summary": "Create a new tag",
                "operationId": "createNotebookTag",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/definitions/NotebookTagRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/NotebookTagResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "get": {
                "summary": "Get tags for user",
                "parameters": [
                    {
                        "name": "userId",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/NotebookTagResponse"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/notebook/tags/{tagId}": {
            "put": {
                "summary": "Update tag",
                "parameters": [
                    {
                        "name": "tagId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/definitions/NotebookTagRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/NotebookTagResponse"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete tag",
                "parameters": [
                    {
                        "name": "tagId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Deleted"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        }
    }
}