							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"portfolioIds\": [\"{{portfolioId}}\"],\n  \"symbols\": [\"AAPL\", \"TSLA\"],\n  \"strategies\": [\"momentum-trading\"],\n  \"startDate\": \"2020-01-01\",\n  \"endDate\": \"2020-12-31\",\n  \"minReturn\": null,\n  \"maxReturn\": null,\n  \"tradeStatus\": [\"OPEN\", \"CLOSED\"],\n  \"sortBy\": \"entryDate\",\n  \"sortDirection\": \"DESC\"\n}"
						},
