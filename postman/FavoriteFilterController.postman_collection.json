	"item": [
		{
			"name": "Filter Management",
			"item": [
				{
					"name": "Create Favorite Filter",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response contains filter data\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('filterId');",
									"    pm.expect(response).to.have.property('name');",
									"    pm.expect(response).to.have.property('filterConfig');",
									"});",
									"",
									"// Save filter ID for other requests",
									"if (pm.response.code === 201) {",
									"    const filterId = pm.response.json().filterId;",
									"    pm.environment.set('filterId', filterId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"High Performing Trades Filter\",\n  \"description\": \"Filter for trades with returns greater than 5%\",\n  \"isDefault\": false,\n  \"filterConfig\": {\n    \"portfolioIds\": [\"{{portfolioId}}\"],\n    \"symbols\": [\"AAPL\", \"TSLA\", \"MSFT\"],\n    \"strategies\": [\"momentum-trading\"],\n    \"startDate\": \"2020-01-01\",\n    \"endDate\": \"2020-12-31\",\n    \"minReturn\": 5.0,\n    \"maxReturn\": null,\n    \"tradeStatus\": [\"CLOSED\"],\n    \"sortBy\": \"totalReturn\",\n    \"sortDirection\": \"DESC\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/filters?userId={{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"filters"
							],
							"query": [
								{
									"key": "userId",
									"value": "{{userId}}"
								}
							]
						}
					},
					"response": []
				},
