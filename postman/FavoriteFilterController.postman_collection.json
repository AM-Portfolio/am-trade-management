					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Current filter saved as favorite\", function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('filterId');",
									"    pm.expect(response).to.have.property('name', 'Current Momentum Strategy');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
